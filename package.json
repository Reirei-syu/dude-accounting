{
  "name": "dude-app",
  "version": "1.1.1",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "Reirei",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:cli": "tsc -p tsconfig.cli.json",
    "test": "vitest run --exclude out/**",
    "qa:electron-breakpoint": "py -3 scripts/electron_breakpoint_audit.py",
    "qa:cli-release-all": "powershell -ExecutionPolicy Bypass -File scripts/prepare-cli-release-e2e.ps1 && npm run build:unpack && node scripts/run-with-utf8.mjs node scripts/cli-release-e2e/run.mjs",
    "cli": "node scripts/run-with-utf8.mjs node scripts/run-cli.mjs",
    "start": "node scripts/run-with-utf8.mjs electron-vite preview",
    "dev": "node scripts/run-with-utf8.mjs electron-vite dev",
    "build": "npm run typecheck && npm run build:cli && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "prepare:self-env": "powershell -ExecutionPolicy Bypass -File scripts/prepare-local-env.ps1",
    "prepare:mac-env": "sh scripts/prepare-mac-env.sh",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-win-installer.ps1",
    "build:mac:installer": "sh scripts/build-mac-installer.sh",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@types/pdfkit": "^0.17.5",
    "better-sqlite3": "^12.6.2",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.17.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.7.4",
    "rcedit": "^5.0.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  }
}
